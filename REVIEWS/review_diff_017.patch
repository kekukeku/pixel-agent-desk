+
+  if (parts.length > 5 && !(parts.length === 6 && parts[5] === '')) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'Invalid session ID' }));
+    return;
+  }
+
+  const validation = validateSessionIdAndGetPath(id, '.json');
